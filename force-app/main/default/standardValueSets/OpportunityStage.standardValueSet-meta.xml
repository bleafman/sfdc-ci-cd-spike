<?xml version="1.0" encoding="UTF-8"?>
<!--
  OpportunityStage StandardValueSet
  =================================
  Defines the picklist values for the Opportunity "Stage" field. In Salesforce,
  Opportunity stages drive the sales pipeline — each stage represents where a
  deal is in the sales process.

  Key concepts for non-Salesforce developers:
  - "standardValue" entries define the allowed picklist options
  - "forecastCategory" maps each stage to a revenue forecasting bucket:
      Pipeline    = early stages, not yet in active forecast
      BestCase    = likely to close but not committed
      Forecast    = committed/expected revenue
      Closed      = deal is done (won or lost)
      Omitted     = excluded from forecast (e.g., Closed Lost)
  - "probability" is the default win likelihood shown on Opportunity records
  - "closed" and "won" flags mark terminal states for reporting and automation
  - The order here determines the display order in the Salesforce UI
-->
<StandardValueSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <sorted>false</sorted>
    <standardValue>
        <fullName>Prospecting</fullName>
        <default>true</default>
        <label>Prospecting</label>
        <closed>false</closed>
        <forecastCategory>Pipeline</forecastCategory>
        <probability>10</probability>
        <won>false</won>
        <description>Initial outreach or inbound interest. No qualified engagement yet.</description>
    </standardValue>
    <standardValue>
        <fullName>Discovery</fullName>
        <default>false</default>
        <label>Discovery</label>
        <closed>false</closed>
        <forecastCategory>Pipeline</forecastCategory>
        <probability>25</probability>
        <won>false</won>
        <description>Active conversations underway. Understanding needs and fit.</description>
    </standardValue>
    <standardValue>
        <fullName>Proposal</fullName>
        <default>false</default>
        <label>Proposal</label>
        <closed>false</closed>
        <forecastCategory>BestCase</forecastCategory>
        <probability>50</probability>
        <won>false</won>
        <description>Formal proposal or quote delivered to the prospect.</description>
    </standardValue>
    <standardValue>
        <fullName>Negotiation</fullName>
        <default>false</default>
        <label>Negotiation</label>
        <closed>false</closed>
        <forecastCategory>Forecast</forecastCategory>
        <probability>75</probability>
        <won>false</won>
        <description>Terms being discussed. Pricing, contract, legal review in progress.</description>
    </standardValue>
    <standardValue>
        <fullName>Closed Won</fullName>
        <default>false</default>
        <label>Closed Won</label>
        <closed>true</closed>
        <forecastCategory>Closed</forecastCategory>
        <probability>100</probability>
        <won>true</won>
        <description>Deal signed. Revenue recognized.</description>
    </standardValue>
    <standardValue>
        <fullName>Closed Lost</fullName>
        <default>false</default>
        <label>Closed Lost</label>
        <closed>true</closed>
        <forecastCategory>Omitted</forecastCategory>
        <probability>0</probability>
        <won>false</won>
        <description>Deal lost. Prospect chose competitor, went dark, or no longer has budget.</description>
    </standardValue>
</StandardValueSet>
